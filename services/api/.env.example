# Application
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS - comma-separated allowed origins (required in production)
# Example: https://your-frontend.com,https://admin.your-frontend.com
CORS_ORIGINS=

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bnb_linebot

# LINE Bot
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# LLM - Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# LLM - Gemini
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Google Calendar / Sheets
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json
GOOGLE_CALENDAR_ID=your_calendar_id_here
GOOGLE_SHEET_ID=your_sheet_id_here

# Supabase Auth (admin panel JWT verification)
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# RAG / Embedding (uses OpenAI API)
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=512
CHUNK_OVERLAP=50
